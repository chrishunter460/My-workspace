' ══════════════════════════════════════════════════════════
' CONFIG LOADING
' ══════════════════════════════════════════════════════════
package "Config Loading" #FFCC66 {

  class BaseTemplate <<dataclass>> {
    + type : str
    + model : str
    + version : str
    + description : str
    + extends : Optional[str]
    + canonical_fields : list[SchemaField]
    + tables : dict[str, TableConfig]
    + depends_on : list[str]
  }

  note bottom of BaseTemplate
    Reusable markdown templates in domains/_base/:
    _base._base_.entity → root entity pattern
    _base.finance.securities → securities pattern
    _base.corporate.earnings → earnings pattern
    _base.accounting.financial_statement → etc.

    Inheritance chain (resolved by extends_resolver):
    _base._base_.entity
      └─ _base.finance.securities
           └─ securities.stocks (model)
                └─ fact_stock_prices (table extends _fact_prices)

    deep_merge: parent fields + child overrides
    Tables/sources can also extend base table templates
  end note

  class DomainConfigLoader {
    - domains_dir : Path
    - _parse_cache : dict
    --
    + load_model_config(model_name) : DomainModelConfig
    + load_all() : dict[str, DomainModelConfig]
    + load_base(base_ref) : BaseTemplate
    + validate_model(model_name) : list[str]
    + validate_all() : dict[str, list[str]]
    + get_inheritance_tree(model_name) : dict
  }

  class config_translator <<module>> {
    + {static} translate_domain_config(config) : dict
  }

  class extends_resolver <<module>> {
    + {static} parse_front_matter(file_path) : dict
    + {static} deep_merge(base, override) : dict
    + {static} resolve_extends_reference(ref, dir, cache) : dict
    + {static} resolve_nested_extends(config, dir, cache) : dict
    + {static} validate_extends_chain(config, dir) : list[str]
    + {static} detect_circular_extends(ref, dir, visited) : bool
    + {static} get_inheritance_chain(ref, dir) : list[str]
  }

  note as ExtendsValidation
    Inheritance validation logic:

    1. resolve: _base.finance.securities
       → find domains/_base/finance/securities.md
       → parse frontmatter → BaseTemplate
       → if not found: raise ConfigurationError

    2. validate chain: no circular extends
       → A extends B extends C extends A → error
       → detect_circular_extends tracks visited set

    3. deep_merge(parent, child):
       → parent canonical_fields + child overrides
       → parent tables merged with child tables
       → child values win at leaf level
       → lists are replaced (not appended)

    4. nested extends (table-level):
       → fact_stock_prices extends _base._fact_prices
       → table schema merged same way
       → validate parent table exists in base

    5. get_inheritance_chain for debugging:
       → returns [root, ..., parent, self]
       → e.g. [_base_.entity, finance.securities, stocks]
  end note

  DomainConfigLoader ..> config_translator : translates
  DomainConfigLoader ..> extends_resolver : resolves + validates inheritance
  DomainConfigLoader ..> BaseTemplate : loads base templates
  BaseTemplate ..> DomainModelConfig : merged into via deep_merge
}

