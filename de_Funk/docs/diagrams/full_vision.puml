' ══════════════════════════════════════════════════════════
' BUILD PATH
' ══════════════════════════════════════════════════════════
package "Build Path" #FF9933 {

  class BaseModelBuilder <<abstract>> {
    + model_name : str
    + depends_on : list[str]
    + session : BuildSession
    --
    + {abstract} get_model_class() : Type
    + validate()
    + pre_build()
    + post_build(result)
    + build() : BuildResult
  }

  class DomainBuilderFactory {
    --
    + {static} create_builders(domains_dir) : dict
  }

  class BaseModel <<abstract>> {
    + session : BuildSession
    + config : DomainModelConfig
    - _dims : dict
    - _facts : dict
    --
    .. build lifecycle (calls hooks) ..
    + build() : tuple[dict, dict]
    + write_tables(output_root, format, mode)
    + get_table(name) : Any
    + has_table(name) : bool
    + list_tables() : list[str]
    .. hook methods (overridable OR config-driven) ..
    + before_build()
    + after_build(dims, facts)
    + custom_node_loading(node_id, config) : Optional[DF]
    .. hook dispatch (config first, then class override) ..
    - _run_hooks(hook_name, **context)
  }

  note bottom of BaseModel
    Hook resolution order:
    1. Check config.hooks.{name} for registered fns
    2. If no config hook, call self.{name}() override
    3. If neither, no-op (default behavior)

    Simple hooks → YAML config (no subclass needed)
    Complex logic → Python subclass override
    Both coexist on same model.
  end note

  class DomainModel {
    .. default for all domains ..
    .. all hooks handled via config ..
    + custom_node_loading(node_id, config)
    .. handles: seed, union, distinct, window, unpivot ..
  }

  class BuildResult <<dataclass>> {
    + model_name : str
    + success : bool
    + rows_written : int
    + duration_seconds : float
    + error : Optional[str]
  }

  BaseModel <|-- DomainModel
  BaseModel ..> BuildSession : uses session
  BaseModelBuilder ..> BuildSession : uses session
  BaseModelBuilder ..> BaseModel : creates + builds
}

' ══════════════════════════════════════════════════════════
' PIPELINE EXECUTOR (config-driven pipeline with hooks)
' ══════════════════════════════════════════════════════════
package "Pipeline Executor" #FF9933 {

  class NodeExecutor {
    .. config-driven pipeline executor ..
    .. dispatches ops from registry ..
    + session : BuildSession
    - _ops : dict[str, Callable]
    --
    .. orchestration ..
    + execute_all(nodes_config) : dict[str, DF]
    + execute_node(node_id, node_config, built) : DF
    + execute_pipeline(df, pipeline_steps) : DF
    .. operation registry ..
    + register_op(name: str, handler: Callable)
    + get_op(name: str) : Callable
    + list_ops() : list[str]
    .. source loading → engine.read ..
    - _load_bronze(ref) : DF
    - _load_silver(model, table) : DF
    - _load_from_node(id, built) : DF
    .. built-in ops → engine methods ..
    - _op_filter(df, cfg)   → engine.filter()
    - _op_join(df, cfg)     → engine.join()
    - _op_select(df, cfg)   → engine.select()
    - _op_derive(df, cfg)   → engine.derive()
    - _op_dedup(df, cfg)    → engine.dedup()
    - _op_drop(df, cfg)     → engine.drop()
    - _op_enrich(df, cfg)   → engine.join() + select()
    - _op_window(df, cfg)   → engine.window()
    - _op_unpivot(df, cfg)  → engine.unpivot()
    - _op_pivot(df, cfg)    → engine.pivot()
    - _op_aggregate(df, cfg) → engine.aggregate()
    - _op_hook(df, cfg)     → calls registered Python fn
    .. special node types ..
    - _build_seed(cfg)      → engine.create_df()
    - _build_union(cfg)     → engine.read() * N + union()
    - _build_distinct(cfg)  → engine.read() + dedup()
    - _build_generated(cfg) → engine.execute_sql() or hook
  }

  note as PipelineConfig
    All hooks declared in YAML config:

    # model.md frontmatter
    hooks:
      after_build:
        - {fn: plugins.company_cik.fix_ids, params: {ticker_col: ticker}}
      post_build:
        - {fn: plugins.technicals.compute_rsi, params: {periods: [14, 30]}}

    # Per-node pipeline (in table config or graph.nodes)
    node: fact_prices
      from: bronze.alpha_vantage_daily
      pipeline:
        - {op: filter, conditions: ["asset_type = 'stock'"]}
        - {op: derive, expressions: {security_id: "HASH(ticker)"}}
        - {op: hook, fn: plugins.company_cik.fix_ids, params: {ticker_col: ticker}}
        - {op: dedup, keys: [security_id, date_id]}

    Backward compatible: no pipeline key =
    implicit order (filter→join→select→derive→dedup)
  end note

  note as OpRegistryNote
    Operation registry (extensible):

    Built-in (registered at init):
      filter, join, select, derive, dedup,
      drop, enrich, window, unpivot, hook

    User-defined:
      executor.register_op("cik_fix", cik_enrichment_fn)
      executor.register_op("technicals", compute_rsi_macd)

    Plugin discovery:
      BuildPluginRegistry.discover("plugins/")
      → auto-registers all @pipeline_op decorated fns

    Hook op signature:
      def my_op(df, engine, config, **params) -> DF
      → receives DataFrame, engine for ops, config for context
  end note

  note as BuildFlow
    Full build orchestration:
    ┌───────────────────────────────────────────────┐
    │ BaseModelBuilder.build()                      │
    │  ├─ validate()                                │
    │  ├─ run config.hooks.pre_build[]   ← FROM CFG │
    │  ├─ BaseModel.build()                         │
    │  │   ├─ run config.hooks.before_build[] ← CFG │
    │  │   ├─ NodeExecutor.execute_all()            │
    │  │   │   for each node:                       │
    │  │   │     ├─ custom_node_loading()           │
    │  │   │     │  (seed/union/calendar)            │
    │  │   │     ├─ READ source                     │
    │  │   │     └─ execute_pipeline(steps):        │
    │  │   │         for each step in node.pipeline:│
    │  │   │           _ops[step.op](df, step)      │
    │  │   │           if op=hook: call step.fn()   │
    │  │   ├─ separate dims / facts                 │
    │  │   ├─ run config.hooks.after_build[] ← CFG  │
    │  │   └─ write_tables()                        │
    │  └─ run config.hooks.post_build[]      ← CFG  │
    └───────────────────────────────────────────────┘

    All hooks declared in YAML frontmatter:
    • hooks.pre_build: [{fn, params}]
    • hooks.before_build: [{fn, params}]
    • hooks.after_build: [{fn, params}]
    • hooks.post_build: [{fn, params}]
    • node.pipeline: [{op: hook, fn, params}]

    Hook fn signature:
      def my_hook(df, engine, config, **params) -> DF
    Always free to deploy any Python.
  end note

  NodeExecutor ..> BuildSession : calls session.engine ops
  NodeExecutor ..> DomainModelConfig : reads pipeline config
  BaseModel *-- NodeExecutor : pipeline execution
}

' ══════════════════════════════════════════════════════════
' HANDLER HIERARCHY (API)
' ══════════════════════════════════════════════════════════
package "Handler Hierarchy (API)" #B3D9FF {

  abstract class ExhibitHandler <<abstract>> {
    + handles : set[str]
    + session : QuerySession
    --
    + {abstract} execute(payload: dict, resolver: Any) : Any
  }

  class HandlerRegistry {
    - _handlers : dict
    + session : QuerySession
    --
    + register(handler)
    + get(type_str) : ExhibitHandler
    + supported_types : set <<property>>
  }

  class GraphicalHandler {
    + handles : {line, bar, scatter, area, pie, heatmap}
    --
    + execute(payload, resolver) : GraphicalResponse
  }

  class PivotHandler {
    + handles : {pivot, great_table, gt}
    --
    + execute(payload, resolver) : GreatTablesResponse
  }

  class MetricsHandler {
    + handles : {cards.metric, kpi}
    --
    + execute(payload, resolver) : MetricResponse
  }

  class BoxHandler {
    + handles : {box, ohlcv, candlestick}
    --
    + execute(payload, resolver) : dict
  }

  class TableDataHandler {
    + handles : {table.data}
    --
    + execute(payload, resolver) : TableResponse
  }

  ExhibitHandler <|-- GraphicalHandler
  ExhibitHandler <|-- PivotHandler
  ExhibitHandler <|-- MetricsHandler
  ExhibitHandler <|-- BoxHandler
  ExhibitHandler <|-- TableDataHandler

  ExhibitHandler ..> QuerySession : uses session
}

' ══════════════════════════════════════════════════════════
' INGESTION PATH
' ══════════════════════════════════════════════════════════
package "Ingestion Path" #CC9966 {

  abstract class BaseProvider <<abstract>> {
    + session : IngestSession
    --
    + {abstract} list_work_items(**kwargs) : list
    + {abstract} fetch(work_item, **kwargs) : Generator
    + {abstract} normalize(records, work_item) : DF
    + {abstract} get_table_name(work_item) : str
  }

  class IngestorEngine {
    + session : IngestSession
    + raw_sink : RawSink
    + bronze_sink : BronzeSink
    --
    + run(provider_id, work_items, **kwargs)
  }

  class RawSink {
    + raw_root : Path
    --
    + write(data, provider, endpoint, partition) : Path
    + exists(provider, endpoint, partition) : bool
    + read(provider, endpoint, partition) : Any
  }

  class BronzeSink {
    + session : IngestSession
    --
    + write_if_missing(table, partitions, df) : bool
    + upsert(df, table, merge_keys, partitions) : str
    + rebuild_from_raw(provider, endpoint) : str
  }

  class HttpClient {
    + base_url : str
    - _token_bucket : TokenBucket
    - _circuit_breaker : CircuitBreaker
    --
    + get(path, params) : Response
  }

  class TokenBucket {
    + rate : float
    + capacity : int
    --
    + acquire(timeout) : bool
  }

  class CircuitBreaker {
    - _state : str
    --
    + call(fn, *args, **kwargs) : Any
    + reset()
  }

  class ApiKeyPool {
    - _keys : list
    --
    + next_key() : str
    + mark_exhausted(key)
  }

  BaseProvider ..> IngestSession : uses session
  IngestorEngine *-- RawSink : writes raw
  IngestorEngine *-- BronzeSink : writes bronze
  RawSink ..> BronzeSink : feeds
  HttpClient *-- TokenBucket : rate limiting
  HttpClient *-- CircuitBreaker : fault tolerance
}

' ══════════════════════════════════════════════════════════
' ORCHESTRATION
' ══════════════════════════════════════════════════════════
package "Orchestration" #CC99FF {

  class PipelineScheduler {
    --
    + add_job(func, trigger, **trigger_args)
    + start()
    + shutdown()
  }

  class DependencyGraph {
    --
    + build()
    + topological_sort() : list[str]
    + filter_buildable(model_names) : list[str]
  }
}

' ══════════════════════════════════════════════════════════
' APPLICATION (top-level wiring — industry standard pattern)
' ══════════════════════════════════════════════════════════
package "Application" #E6E6E6 {

  class DeFunk {
    + config : AppConfig
    + engine : Engine
    + graph : DomainGraph
    + models : dict[str, DomainModelConfig]
    + providers : dict[str, ProviderConfig]
    + endpoints : dict[str, EndpointConfig]
    --
    + {static} from_config(config_path: Path) : DeFunk
    + {static} from_app_config(config: AppConfig) : DeFunk
    + build_session(**kwargs) : BuildSession
    + query_session(**kwargs) : QuerySession
    + ingest_session(**kwargs) : IngestSession
  }

  note right of DeFunk
    Top-level application object.
    Assembles everything from config:
    1. ConfigLoader → AppConfig
    2. DomainConfigLoader → models
    3. DomainGraph from EdgeSpecs
    4. Engine from ConnectionConfig
    5. Session factories with right config slices

    Usage:
      app = DeFunk.from_config("configs/")
      session = app.build_session()
      session.build("securities.stocks")
  end note

  class ConfigLoader {
    --
    + load(connection_type, log_level) : AppConfig
  }

  class AppConfig <<dataclass>> {
    + repo_root : Path
    + connection : ConnectionConfig
    + storage : StorageConfig
    + run : RunConfig
    + apis : dict[str, APIConfig]
  }

  AppConfig *-- RunConfig : runtime settings

  class ConnectionFactory {
    + {static} create(connection_type, **kwargs) : DataConnection
  }

  ConfigLoader ..> AppConfig : produces
  DeFunk *-- AppConfig : config
  DeFunk *-- Engine : engine
  DeFunk *-- DomainGraph : graph
  DeFunk *-- ArtifactStore : artifacts
  DeFunk ..> DomainConfigLoader : loads models
  DeFunk ..> IngestSession : creates
  DeFunk ..> BuildSession : creates
  DeFunk ..> QuerySession : creates
}

' ══════════════════════════════════════════════════════════
' MODEL ARTIFACTS (trained ML models — separate from Silver data)
' ══════════════════════════════════════════════════════════
package "Model Artifacts" #B3FFB3 {

  class ModelArtifact <<dataclass>> {
    + model_name : str
    + version : str
    + trained_at : datetime
    + artifact_path : Path
    + metrics : dict
    + config : dict
    + status : str
  }

  class ArtifactStore {
    + models_root : Path
    --
    + save(artifact: ModelArtifact, model_object: Any) : Path
    + load(model_name, version) : tuple[ModelArtifact, Any]
    + latest(model_name) : tuple[ModelArtifact, Any]
    + list_versions(model_name) : list[ModelArtifact]
    + register(artifact: ModelArtifact)
  }

  note as ArtifactNote
    Forecast YAML config:
    hooks:
      post_build:
        - {fn: plugins.forecast.train_and_save,
           params: {methods: [arima, prophet],
                    horizon: 30,
                    retrain_if_stale_days: 7}}

    Storage layout:
    /storage/models/{model_name}/{version}/
      model.pkl          ← trained model artifact
      metadata.json      ← ModelArtifact fields
      metrics.json       ← accuracy metrics

    Results written to Silver:
    /storage/silver/forecast/facts/fact_forecast_price/
    /storage/silver/forecast/dims/dim_model_registry/

    Recall: ArtifactStore.load("arima_aapl", "v3")
    Retrain: PipelineScheduler checks staleness
  end note

  ArtifactStore *-- ModelArtifact : manages
  ArtifactStore ..> StorageRouter : model_path()
}

