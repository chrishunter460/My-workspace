    --
    + {static} register(hook_type, model_name, fn)
    + {static} get(hook_type, model_name) : list
    + {static} discover(plugins_dir)
  }
}

' ══════════════════════════════════════════════════════════
' KEY RELATIONSHIPS
' ══════════════════════════════════════════════════════════

' Config loading
DomainBuilderFactory ..> DomainConfigLoader : loads configs
DomainConfigLoader ..> DomainModelConfig : produces
AppConfig *-- ConnectionConfig : connection
AppConfig *-- StorageConfig : storage
ConnectionFactory ..> DataConnection : creates
DeFunk ..> ConnectionFactory : uses to create engine

' Orchestration → Build
PipelineScheduler ..> DependencyGraph : build order
PipelineScheduler ..> DeFunk : creates sessions via
PipelineScheduler ..> BaseModelBuilder : triggers builds
DomainBuilderFactory ..> BuildSession : injects into builders
DependencyGraph ..> DomainModelConfig : reads depends_on

' Pipeline executor
' NodeExecutor -> BuildSession edge is in Pipeline Executor package
BuildPluginRegistry ..> NodeExecutor : registers ops into

' Ingestion
IngestorEngine ..> IngestSession : uses session
IngestorEngine *-- BaseProvider : orchestrates
BaseProvider ..> HttpClient : fetches via
BronzeSink ..> IngestSession : uses session

' Provider ↔ Endpoint
ProviderConfig ..> EndpointConfig : lists endpoints

